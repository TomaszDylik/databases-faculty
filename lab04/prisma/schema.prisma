// This is your Prisma schema file — the single source of truth for DB structure and types.
// Any schema change + `prisma migrate dev` is the only right way to modify the database.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Power {
  flight
  strength
  telepathy
  speed
  invisibility
}

enum HeroStatus {
  available
  busy
  retired
}

enum IncidentLevel {
  low
  medium
  critical
}

enum IncidentStatus {
  open
  assigned
  resolved
}

// ─── Models ──────────────────────────────────────────────────────────────────

model Hero {
  id            Int        @id @default(autoincrement())
  // @unique enforces DB-level unique constraint on the heroes table
  name          String     @unique @db.VarChar(120)
  power         Power
  // @default(available) sets the DEFAULT in the generated migration
  status        HeroStatus @default(available)
  missionsCount Int        @default(0) @map("missions_count")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")
  status2       Int?       
  // virtual field — Prisma does NOT create a column, only enables include/select on the relation
  incidents     Incident[]

  // @@map maps the Prisma model name (Hero) to the actual postgres table name (heroes)
  @@map("heroes")
}

model Incident {
  id                Int            @id @default(autoincrement())
  location          String
  district          String?
  level             IncidentLevel
  status            IncidentStatus @default(open)
  heroId            Int?           @map("hero_id")
  assignedAt        DateTime?      @map("assigned_at")
  resolvedAt        DateTime?      @map("resolved_at")
  // Float maps to DOUBLE PRECISION in postgres — simpler than Decimal for resolutions
  resolutionMinutes Float?         @map("resolution_minutes")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  // @relation defines the FK column + onDelete behaviour → generates correct ALTER TABLE in migration
  hero       Hero?              @relation(fields: [heroId], references: [id], onDelete: SetNull)
  // M:N through explicit junction table — Prisma requires explicit IncidentCategory model
  categories IncidentCategory[]

  @@map("incidents")
}

model Category {
  id        Int                @id @default(autoincrement())
  name      String             @unique @db.VarChar(80)
  incidents IncidentCategory[]

  @@map("categories")
}

model IncidentCategory {
  incidentId Int @map("incident_id")
  categoryId Int @map("category_id")

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  // @@id creates a composite primary key — no separate id column needed on junction tables
  @@id([incidentId, categoryId])
  @@map("incident_categories")
}
