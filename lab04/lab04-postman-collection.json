{
  "info": {
    "name": "Lab04 — Prisma ORM",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",           "value": "http://localhost:3000/api/v1" },
    { "key": "heroId",            "value": "130",  "description": "ID bohatera (sprawdź GET /heroes)" },
    { "key": "availableHeroId",   "value": "130",  "description": "ID bohatera ze statusem available" },
    { "key": "openIncidentId",    "value": "308",  "description": "ID incydentu ze statusem open" },
    { "key": "assignedIncidentId","value": "307",  "description": "ID incydentu ze statusem assigned" }
  ],
  "item": [
    {
      "name": "Heroes",
      "item": [
        {
          "name": "GET /heroes",
          "request": { "method": "GET", "url": "{{baseUrl}}/heroes" }
        },
        {
          "name": "POST /heroes",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/heroes",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Test Hero\",\n  \"power\": \"flight\"\n}" }
          }
        },
        {
          "name": "GET /heroes/:id",
          "request": { "method": "GET", "url": "{{baseUrl}}/heroes/{{heroId}}" }
        },
        {
          "name": "PATCH /heroes/:id",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/heroes/{{heroId}}",
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"retired\"\n}" }
          }
        },
        {
          "name": "GET /heroes/:id/incidents",
          "request": { "method": "GET", "url": "{{baseUrl}}/heroes/{{heroId}}/incidents" }
        }
      ]
    },
    {
      "name": "Incidents",
      "item": [
        {
          "name": "GET /incidents",
          "request": { "method": "GET", "url": "{{baseUrl}}/incidents" }
        },
        {
          "name": "POST /incidents",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/incidents",
            "body": { "mode": "raw", "raw": "{\n  \"location\": \"Park Avenue\",\n  \"level\": \"medium\",\n  \"categoryIds\": [26, 27]\n}" }
          }
        },
        {
          "name": "GET /incidents/:id",
          "request": { "method": "GET", "url": "{{baseUrl}}/incidents/{{openIncidentId}}" }
        },
        {
          "name": "POST /incidents/:id/assign",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/incidents/{{openIncidentId}}/assign",
            "body": { "mode": "raw", "raw": "{\n  \"heroId\": {{availableHeroId}}\n}" }
          }
        },
        {
          "name": "PATCH /incidents/:id/resolve",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/incidents/{{assignedIncidentId}}/resolve",
            "body": { "mode": "raw", "raw": "{}" }
          }
        }
      ]
    },
    {
      "name": "Stats",
      "item": [
        {
          "name": "GET /stats",
          "request": { "method": "GET", "url": "{{baseUrl}}/stats" }
        }
      ]
    }
  ]
}
