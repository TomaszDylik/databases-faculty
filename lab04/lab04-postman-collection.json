{
  "info": {
    "name": "lab04",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base", "value": "http://localhost:3000/api/v1" }
  ],
  "item": [
    {
      "name": "POST /incidents",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{base}}/incidents", "host": ["{{base}}"], "path": ["incidents"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"location\": \"Centrum\",\n  \"level\": \"critical\",\n  \"categoryIds\": [1, 2]\n}"
        }
      }
    },
    {
      "name": "GET /incidents/:id",
      "request": {
        "method": "GET",
        "url": { "raw": "{{base}}/incidents/1", "host": ["{{base}}"], "path": ["incidents", "1"] }
      }
    },
    {
      "name": "GET /incidents?categoryId=1",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base}}/incidents?categoryId=1",
          "host": ["{{base}}"],
          "path": ["incidents"],
          "query": [{ "key": "categoryId", "value": "1" }]
        }
      }
    },
    {
      "name": "GET /incidents?exclude=1",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base}}/incidents?exclude=1",
          "host": ["{{base}}"],
          "path": ["incidents"],
          "query": [{ "key": "exclude", "value": "1" }]
        }
      }
    },
    {
      "name": "POST /incidents/:id/assign",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{base}}/incidents/1/assign", "host": ["{{base}}"], "path": ["incidents", "1", "assign"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"heroId\": 1\n}"
        }
      }
    },
    {
      "name": "PATCH /incidents/:id/resolve",
      "request": {
        "method": "PATCH",
        "url": { "raw": "{{base}}/incidents/1/resolve", "host": ["{{base}}"], "path": ["incidents", "1", "resolve"] }
      }
    },
    {
      "name": "GET /stats",
      "request": {
        "method": "GET",
        "url": { "raw": "{{base}}/stats", "host": ["{{base}}"], "path": ["stats"] }
      }
    }
  ]
}
