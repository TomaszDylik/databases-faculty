{
  "info": {
    "name": "Lab04",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",            "value": "http://localhost:3000/api/v1" },
    { "key": "heroId",             "value": "220" },
    { "key": "openIncidentId",     "value": "614" },
    { "key": "assignedIncidentId", "value": "613" },
    { "key": "categoryId",         "value": "51" },
    { "key": "excludeCategoryId",  "value": "52" }
  ],
  "item": [
    {
      "name": "Zagniezdzone zapisy",
      "item": [
        {
          "name": "POST /incidents",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/incidents",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"location\": \"Test Street 1\",\n  \"level\": \"medium\",\n  \"categoryIds\": [51, 52]\n}"
            }
          }
        },
        {
          "name": "GET /incidents/:id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/incidents/{{openIncidentId}}"
          }
        },
        {
          "name": "GET /incidents?categoryId=",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/incidents?categoryId={{categoryId}}"
          }
        },
        {
          "name": "GET /incidents?exclude=",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/incidents?exclude={{excludeCategoryId}}"
          }
        }
      ]
    },
    {
      "name": "Transakcje",
      "item": [
        {
          "name": "POST /incidents/:id/assign",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/incidents/{{openIncidentId}}/assign",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"heroId\": {{heroId}}\n}"
            }
          }
        },
        {
          "name": "PATCH /incidents/:id/resolve",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/incidents/{{assignedIncidentId}}/resolve",
            "body": {
              "mode": "raw",
              "raw": "{}"
            }
          }
        },
        {
          "name": "GET /heroes/:id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/heroes/{{heroId}}"
          }
        }
      ]
    },
    {
      "name": "Stats",
      "item": [
        {
          "name": "GET /stats",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/stats"
          }
        }
      ]
    }
  ]
}
