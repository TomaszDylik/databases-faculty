{
  "info": {
    "name": "Lab04 — Prisma ORM",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",          "value": "http://localhost:3000/api/v1" },
    { "key": "heroId",           "value": "21", "description": "ID dowolnego bohatera (sprawdź GET /heroes)" },
    { "key": "availableHeroId",  "value": "22", "description": "ID bohatera ze statusem available (do assign)" },
    { "key": "openIncidentId",   "value": "62", "description": "ID incydentu ze statusem open (do assign)" },
    { "key": "assignedIncidentId","value": "63", "description": "ID incydentu ze statusem assigned (do resolve)" }
  ],
  "item": [
    {
      "name": "Heroes",
      "item": [
        {
          "name": "GET /heroes — lista",
          "request": { "method": "GET", "url": "{{baseUrl}}/heroes" }
        },
        {
          "name": "GET /heroes?status=available",
          "request": { "method": "GET", "url": "{{baseUrl}}/heroes?status=available" }
        },
        {
          "name": "GET /heroes?power=flight",
          "request": { "method": "GET", "url": "{{baseUrl}}/heroes?power=flight" }
        },
        {
          "name": "GET /heroes?sortBy=missions_count&sortDir=desc&pageSize=5",
          "request": { "method": "GET", "url": "{{baseUrl}}/heroes?sortBy=missions_count&sortDir=desc&pageSize=5" }
        },
        {
          "name": "POST /heroes — utwórz bohatera",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/heroes",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Test Hero\",\n  \"power\": \"flight\"\n}" }
          }
        },
        {
          "name": "GET /heroes/:id",
          "request": { "method": "GET", "url": "{{baseUrl}}/heroes/{{heroId}}" }
        },
        {
          "name": "PATCH /heroes/:id — zmiana statusu",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/heroes/{{heroId}}",
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"retired\"\n}" }
          }
        },
        {
          "name": "PATCH /heroes/:id — zmiana nazwy i mocy",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/heroes/{{heroId}}",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Nova Storm\",\n  \"power\": \"strength\"\n}" }
          }
        },
        {
          "name": "PATCH /heroes/:id — błędna wartość (422)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/heroes/{{heroId}}",
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"unavailable\"\n}" }
          }
        },
        {
          "name": "GET /heroes/:id/incidents",
          "request": { "method": "GET", "url": "{{baseUrl}}/heroes/{{heroId}}/incidents" }
        }
      ]
    },
    {
      "name": "Incidents",
      "item": [
        {
          "name": "GET /incidents — lista",
          "request": { "method": "GET", "url": "{{baseUrl}}/incidents" }
        },
        {
          "name": "GET /incidents?level=critical",
          "request": { "method": "GET", "url": "{{baseUrl}}/incidents?level=critical" }
        },
        {
          "name": "GET /incidents?status=open",
          "request": { "method": "GET", "url": "{{baseUrl}}/incidents?status=open" }
        },
        {
          "name": "GET /incidents?categoryId=1",
          "request": { "method": "GET", "url": "{{baseUrl}}/incidents?categoryId=1" }
        },
        {
          "name": "GET /incidents?exclude=2",
          "request": { "method": "GET", "url": "{{baseUrl}}/incidents?exclude=2" }
        },
        {
          "name": "POST /incidents — utwórz incydent",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/incidents",
            "body": { "mode": "raw", "raw": "{\n  \"location\": \"Park Avenue\",\n  \"level\": \"medium\",\n  \"categoryIds\": [1, 2]\n}" }
          }
        },
        {
          "name": "GET /incidents/:id",
          "request": { "method": "GET", "url": "{{baseUrl}}/incidents/{{openIncidentId}}" }
        },
        {
          "name": "POST /incidents/:id/assign — przypisz bohatera",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/incidents/{{openIncidentId}}/assign",
            "body": { "mode": "raw", "raw": "{\n  \"heroId\": {{availableHeroId}}\n}" }
          }
        },
        {
          "name": "PATCH /incidents/:id/resolve — rozwiąż incydent",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/incidents/{{assignedIncidentId}}/resolve",
            "body": { "mode": "raw", "raw": "{}" }
          }
        }
      ]
    },
    {
      "name": "Stats",
      "item": [
        {
          "name": "GET /stats — podsumowanie",
          "request": { "method": "GET", "url": "{{baseUrl}}/stats" }
        }
      ]
    }
  ]
}
